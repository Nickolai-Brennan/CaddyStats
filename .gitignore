# =============================================================================
# CaddyStats — .gitignore
# =============================================================================

# Environment
.env
.env.local
.env.*.local
!.env.example

# Node / pnpm
node_modules/
.pnpm-store/
.pnpm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
.vite/
out/

# TurboRepo cache
.turbo/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.venv/
venv/
env/
.Python
*.egg-info/
dist/
*.egg
.installed.cfg
pip-selfcheck.json

# Testing / Coverage
.pytest_cache/
.coverage
coverage/
coverage.xml
htmlcov/
*.lcov
.nyc_output/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
pyrightconfig.json

# Linters
.ruff_cache/

# Docker
*.log

# IDE / Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Secrets / keys
*.pem
*.key
*.p12
*.pfx
secrets/

# Alembic
alembic/versions/*.pyc

# Monitoring
infrastructure/monitoring/grafana/data/
infrastructure/monitoring/prometheus/data/

# Terraform
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/.terraform.lock.hcl
