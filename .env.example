# =============================================================================
# Caddy Stats — Shared environment baseline
# =============================================================================
# Copy this file to .env for local development.
# Environment-specific overlays live in config/environments/.
# Never commit real secrets or any populated .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment routing
# -----------------------------------------------------------------------------
APP_ENV=local
NODE_ENV=development
DEPLOY_ENV=local
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# App / security baseline
# -----------------------------------------------------------------------------
APP_SECRET_KEY=change-me-to-a-long-random-secret
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CSP_REPORT_ONLY=true
CSP_REPORT_URI=
SECURITY_HEADERS_ENABLED=true

# -----------------------------------------------------------------------------
# API service (active runtime: services/api; canonical boundary: api/ + backend/)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1
API_LOG_LEVEL=info
FASTAPI_ENV=development
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
GRAPHQL_PLAYGROUND_ENABLED=true

# -----------------------------------------------------------------------------
# Frontend (active runtime: apps/web; canonical boundary: frontend/)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=CaddyStats
VITE_APP_ENV=local
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=db_golf
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/db_golf
DATABASE_SSL_MODE=disable

# -----------------------------------------------------------------------------
# NeonDB
# -----------------------------------------------------------------------------
NEON_ROLE=neondb_owner
NEON_DB=Caddy Stats
NEON_CONNECTION=psql 'postgresql://neondb_owner:npg_f05LaYmeJjhS@ep-nameless-cell-aq0eumdw-pooler.c-8.us-east-1.aws.neon.tech/Caddy%20Stats?sslmode=require&channel_binding=require'

# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# -----------------------------------------------------------------------------
# Docker / local stack
# -----------------------------------------------------------------------------
DOCKER_ENV=development
DOCKER_PROJECT_NAME=caddystats
COMPOSE_PROFILES=default

# -----------------------------------------------------------------------------
# Managed services / observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
PROMETHEUS_RETENTION=15d
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=caddystats

# -----------------------------------------------------------------------------
# Data / analytics services
# -----------------------------------------------------------------------------
MOTHERDUCK_TOKEN=
MOTHERDUCK_DATABASE=CaddyStats
MOTHERDUCK_URL=md:CaddyStats
DUCKDB_PATH=./data/caddystats.duckdb
DUCKD_HOST=0.0.0.0
DUCKD_PORT=4213

# -----------------------------------------------------------------------------
# External data providers
# -----------------------------------------------------------------------------
PGA_TOUR_API_KEY=
DATAGOLF_API_KEY=
ODDS_API_KEY=
WEATHER_API_KEY=

# -----------------------------------------------------------------------------
# AI / editorial assist
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL_DEFAULT=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_REVIEW_REQUIRED=true

# -----------------------------------------------------------------------------
# Billing / email
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@caddystats.com

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
FEATURE_AI_ENABLED=false
FEATURE_BETTING_ENABLED=false
FEATURE_SUBSCRIPTIONS_ENABLED=false
