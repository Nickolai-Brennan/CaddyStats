# =============================================================================
# Caddy Stats — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-secret

# -----------------------------------------------------------------------------
# API Service
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1
API_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=caddystats
POSTGRES_USER=caddystats
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://caddystats:change-me-postgres-password@postgres:5432/caddystats

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Frontend (Web App)
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=CaddyStats
VITE_APP_ENV=development

# -----------------------------------------------------------------------------
# External Data Providers
# -----------------------------------------------------------------------------
PGA_TOUR_API_KEY=
DATAGOLF_API_KEY=
ODDS_API_KEY=
WEATHER_API_KEY=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL_DEFAULT=gpt-4o
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# -----------------------------------------------------------------------------
# Billing (Stripe)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@caddystats.com

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
PROMETHEUS_RETENTION=15d

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_AI_ENABLED=false
FEATURE_BETTING_ENABLED=false
FEATURE_SUBSCRIPTIONS_ENABLED=false
