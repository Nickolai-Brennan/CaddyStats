# CaddyStats Web App Environment Variables

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_GRAPHQL_URL=http://localhost:8000/graphql

# App Configuration
VITE_APP_NAME=CaddyStats
VITE_APP_VERSION=0.1.0

# Feature Flags
VITE_ENABLE_BETA_FEATURES=false
VITE_ENABLE_DEBUG_TOOLBAR=false

# Analytics
VITE_ANALYTICS_ID=

# Error Tracking (Sentry)
VITE_SENTRY_DSN=

# Auth
VITE_AUTH_REDIRECT_URI=http://localhost:5173

# Cache Strategy (memory | indexeddb | hybrid)
VITE_CACHE_STRATEGY=memory
