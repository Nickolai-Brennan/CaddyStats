{
  "name": "caddystats",
  "version": "0.0.1",
  "private": true,
  "description": "Caddy Stats — production-grade golf analytics, content, and betting intelligence platform",
  "scripts": {
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "pnpm hooks:install || true",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9"
}
